{
  "name": "@gsknnft/agent-chat",
  "version": "0.1.0",
  "description": "Reusable floating agent chat widget for SigilNet apps — connects to any OpenAI-compatible SSE backend.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "react": ">=19.2.4"
  }
}
